{
  "name": "cron-jobs",
  "version": "1.0.0",
  "description": "Thrico Cron Jobs - Periodic task execution service",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@thrico/database": "workspace:*",
    "@thrico/logging": "workspace:*",
    "@thrico/services": "workspace:*",
    "@thrico/shared": "workspace:*",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.29.1",
    "moment": "^2.30.1",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.20",
    "@types/node-cron": "^3.0.11",
    "nodemon": "^3.1.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  }
}
