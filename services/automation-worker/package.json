{
  "name": "automation-worker",
  "version": "1.0.0",
  "description": "Thrico Automation Worker - Executes background jobs from automation",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@thrico/database": "workspace:*",
    "@thrico/logging": "workspace:*",
    "@thrico/services": "workspace:*",
    "@thrico/shared": "workspace:*",
    "bullmq": "^5.12.10",
    "dotenv": "^16.4.5",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  }
}
