{
  "name": "live",
  "version": "1.0.0",
  "description": "Thrico Live – Mediasoup SFU signaling server (Instagram-style live streaming)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=4096' nodemon --exec tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@thrico/database": "workspace:*",
    "@thrico/logging": "workspace:*",
    "@thrico/shared": "workspace:*",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mediasoup": "^3.14.14",
    "redis": "^5.10.0",
    "socket.io": "^4.7.5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.5",
    "@types/uuid": "^9.0.7",
    "@types/bcrypt": "^5.0.2",
    "nodemon": "^3.1.11",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
